{
  "name": "forgecut-ui",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "Alex Wanyoike",
    "email": "alex.m.wanyoike@gmail.com"
  },
  "homepage": "https://github.com/alexanderwanyoike/forgecut",
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "node electron/scripts/dev.mjs",
    "dev:web": "vite",
    "dev:electron": "yarn dev",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "tsc && vite build",
    "build": "yarn build:renderer && yarn build:electron",
    "verify:electron": "node electron/scripts/verify-startup.mjs",
    "package": "yarn build && electron-builder --publish never",
    "package:linux": "yarn build && electron-builder --linux --publish never",
    "package:mac": "yarn build && electron-builder --mac --publish never",
    "package:win": "yarn build && electron-builder --win --publish never",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
